{
  "include": [
    "src",
    "scripts/test",
    "tests/unit"
  ],
  "exclude": [
    ".venv",
    "htmlcov",
    "__pycache__"
  ],
  "venvPath": ".",
  "venv": ".venv",
  "pythonVersion": "3.11",
  "typeCheckingMode": "standard",
  "reportMissingModuleSource": "none",
  "reportMissingTypeStubs": "none",
  "reportUnknownMemberType": "warning",
  "reportUnknownVariableType": "warning",
  "reportUnknownArgumentType": "warning"
}
