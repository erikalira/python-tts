{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Discord Bot",
      "type": "debugpy",
      "request": "launch",
      "module": "src.bot",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}\\.env",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Python: Desktop App",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\app.py",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}\\.env",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ],
  "compounds": [
    {
      "name": "Python: Bot + Desktop App",
      "configurations": [
        "Python: Discord Bot",
        "Python: Desktop App"
      ]
    }
  ]
}
