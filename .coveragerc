[run]
source = src/
omit = 
    */tests/*
    */__pycache__/*
    */venv/*
    */.venv/*
    setup.py
    conftest.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod

skip_covered = False
show_missing = True

[html]
directory = htmlcov

[xml]
output = coverage.xml
