# Production example for the Discord bot service in cloud deploys
# This file documents the variables used by the bot runtime in deploys.

# Required: Discord bot token from the Discord Developer Portal.
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN

# Required for public HTTP services and recommended for private cloud deploys too.
DISCORD_BOT_HOST=0.0.0.0

# Many cloud platforms provide PORT automatically.
# Keep this here as documentation or for manual overrides.
PORT=10000

# Optional TTS overrides. If omitted, the bot uses the built-in defaults below.
TTS_ENGINE=gtts
TTS_LANGUAGE=pt
TTS_VOICE_ID=roa/pt-br
TTS_RATE=180

# Optional request size limit for the HTTP API.
MAX_TEXT_LENGTH=500

# Dockerized Postgres settings used by docker-compose.postgres.yml.
# The bundled compose file derives DATABASE_URL from these values.
CONFIG_STORAGE_BACKEND=postgres
POSTGRES_DB=tts_db
POSTGRES_USER=tts_user
POSTGRES_PASSWORD=change_me
