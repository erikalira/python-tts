# Production example for the Discord bot service in cloud deploys
# This file documents the variables used by the bot runtime in deploys.

# Required: Discord bot token from the Discord Developer Portal.
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN

# Required for public HTTP services and recommended for private cloud deploys too.
DISCORD_BOT_HOST=0.0.0.0

# Application release identity used by docker-compose.prod.yml.
# Use immutable tags in production, for example v2026.04.24-1 or a git SHA.
BOT_IMAGE=tts-hotkey-windows-bot
APP_VERSION=local
VCS_REF=unknown

# Many cloud platforms provide PORT automatically.
# Keep this here as documentation or for manual overrides.
PORT=10000

# Logging verbosity for the bot runtime. Keep INFO in normal operation and switch
# to DEBUG temporarily when you need detailed per-request diagnostics.
LOG_LEVEL=INFO

# Optional TTS overrides. If omitted, the bot uses the built-in defaults below.
TTS_ENGINE=gtts
TTS_LANGUAGE=pt
TTS_VOICE_ID=roa/pt-br
TTS_RATE=180

# Optional request size limit for the HTTP API.
MAX_TEXT_LENGTH=500

# Optional browser CORS allowlist for bot HTTP endpoints. Empty is recommended
# unless a browser client is intentionally deployed.
BOT_HTTP_CORS_ALLOWED_ORIGINS=

# Required when DISCORD_BOT_HOST is not loopback. Keep this in the deployment
# secret store; this example value must be replaced before production use.
BOT_SPEAK_TOKEN=change_me

# Maximum accepted HTTP request body size for bot endpoints, in bytes.
BOT_HTTP_MAX_BODY_BYTES=4096

# Bot runtime rate limit for /speak entrypoints. Set max requests to 0 to disable.
BOT_RATE_LIMIT_MAX_REQUESTS=8
BOT_RATE_LIMIT_WINDOW_SECONDS=10

# Dockerized Postgres settings used by docker-compose.prod.yml and docker-compose.postgres.yml.
# The bundled compose file derives DATABASE_URL from these values.
CONFIG_STORAGE_BACKEND=postgres
POSTGRES_DB=tts_db
POSTGRES_USER=tts_user
POSTGRES_PASSWORD=change_me

# Dockerized Redis queue settings used by docker-compose.prod.yml.
TTS_QUEUE_BACKEND=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_KEY_PREFIX=tts
REDIS_COMPLETED_ITEM_TTL_SECONDS=900

# Optional OpenTelemetry OTLP export.
OTEL_ENABLED=true
OTEL_SERVICE_NAME=tts-hotkey-windows-bot
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# Grafana access for the bundled observability stack.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me
