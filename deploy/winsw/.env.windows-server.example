# Windows Server example for running the Discord bot with WinSW.
# Copy this file to the repository root as .env on the server and fill in real values.

DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN

# Use 0.0.0.0 when the Desktop App or other clients need to reach the bot from another machine.
DISCORD_BOT_HOST=0.0.0.0
DISCORD_BOT_PORT=10000

# Optional TTS overrides.
TTS_ENGINE=gtts
TTS_LANGUAGE=pt
TTS_VOICE_ID=roa/pt-br
TTS_RATE=180

# Optional HTTP request limit.
MAX_TEXT_LENGTH=500
