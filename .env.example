# Local development example
# Copy this file to .env and adjust only the values you need locally.

# Required for the Discord bot runtime.
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN

# Used by the Desktop App to reach the bot in local development.
DISCORD_BOT_URL=http://localhost:10000

# Local fallback port for the bot runtime when PORT is not set.
DISCORD_BOT_PORT=10000

# Optional desktop defaults.
DISCORD_MEMBER_ID=

# Optional TTS overrides shared by bot and Desktop App.
TTS_ENGINE=gtts
TTS_LANGUAGE=pt
TTS_VOICE_ID=roa/pt-br
TTS_RATE=180
TTS_OUTPUT_DEVICE=

# Bot config persistence backend.
CONFIG_STORAGE_BACKEND=json
CONFIG_STORAGE_DIR=configs

# Required only when CONFIG_STORAGE_BACKEND=postgres.
DATABASE_URL=

# Discord bot audio queue backend.
TTS_QUEUE_BACKEND=inmemory
TTS_QUEUE_MAX_SIZE=50

# Required when TTS_QUEUE_BACKEND=redis.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_KEY_PREFIX=tts
REDIS_COMPLETED_ITEM_TTL_SECONDS=900

# Optional OpenTelemetry OTLP export.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=tts-hotkey-windows-bot
OTEL_EXPORTER_OTLP_ENDPOINT=
