# Discord Bot Configuration
# Copy this file to .env and fill in your actual values

# Required: Your Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN="YOUR_ACTUAL_DISCORD_TOKEN_HERE"

# Optional: Bot endpoint URL (for Desktop App connecting to Discord bot)
DISCORD_BOT_URL=http://localhost:10000

# Optional: HTTP port used by the Discord bot runtime
DISCORD_BOT_PORT=10000

# Optional: Discord Member ID (obtained from Discord settings)
DISCORD_MEMBER_ID=your_user_id_here

# TTS Configuration
TTS_ENGINE=gtts
TTS_LANGUAGE=pt
TTS_VOICE_ID=roa/pt-br
TTS_RATE=180
