# Local development example
# Copy this file to .env and adjust only the values you need locally.

# Required for the Discord bot runtime.
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN

# Optional Docker release identity for local compose smoke tests.
BOT_IMAGE=tts-hotkey-windows-bot
APP_VERSION=local
VCS_REF=unknown

# Used by the Desktop App to reach the bot in local development.
DISCORD_BOT_URL=http://localhost:10000

# Local fallback port for the bot runtime when PORT is not set.
DISCORD_BOT_PORT=10000

# Optional browser CORS allowlist for bot HTTP endpoints. Empty means no browser
# origins are allowed. Local Desktop App calls do not need CORS.
BOT_HTTP_CORS_ALLOWED_ORIGINS=

# Optional shared token for POST /speak. Required when the bot HTTP host is not
# loopback. The Desktop App sends this value as X-Bot-Token when present.
BOT_SPEAK_TOKEN=

# Bot runtime rate limit for /speak entrypoints. Set max requests to 0 to disable.
BOT_RATE_LIMIT_MAX_REQUESTS=8
BOT_RATE_LIMIT_WINDOW_SECONDS=10

# Logging verbosity for the bot runtime. Use DEBUG only when investigating issues.
LOG_LEVEL=INFO

# Optional desktop defaults.
DISCORD_MEMBER_ID=

# Optional TTS overrides shared by bot and Desktop App.
TTS_ENGINE=gtts
TTS_LANGUAGE=pt
TTS_VOICE_ID=roa/pt-br
TTS_RATE=180
TTS_OUTPUT_DEVICE=

# Bot config persistence backend.
CONFIG_STORAGE_BACKEND=json
CONFIG_STORAGE_DIR=configs

# Required only when CONFIG_STORAGE_BACKEND=postgres.
DATABASE_URL=postgresql://tts_user:change_me@127.0.0.1:5432/tts_hotkey_windows
POSTGRES_DB=tts_hotkey_windows
POSTGRES_USER=tts_user
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# Discord bot audio queue backend.
TTS_QUEUE_BACKEND=inmemory
TTS_QUEUE_MAX_SIZE=50

# Required when TTS_QUEUE_BACKEND=redis.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_KEY_PREFIX=tts
REDIS_COMPLETED_ITEM_TTL_SECONDS=900

# Optional OpenTelemetry OTLP export.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=tts-hotkey-windows-bot
OTEL_EXPORTER_OTLP_ENDPOINT=
