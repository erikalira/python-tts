# Discord Bot Configuration
# Copy this file to .env and fill in your actual values

# Required: Your Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN="YOUR_ACTUAL_DISCORD_TOKEN_HERE"

# Optional: Port for the bot's HTTP endpoint (default: 5000)
DISCORD_BOT_PORT=5000

# Optional: URL for the hotkey app to send TTS requests (default: not set)
DISCORD_BOT_URL=http://localhost:10000

# Optional: Flask health endpoint port (default: 8080, only used with run_with_flask.py)
PORT=10000


# TTS Configuration
TTS_ENGINE=gtts
TTS_LANGUAGE=pt
TTS_VOICE_ID=roa/pt-br